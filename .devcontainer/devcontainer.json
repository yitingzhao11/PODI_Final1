{
  "name": "Streamlit Classic (pip)",

  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "streamlit_app.py"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "updateContentCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt",

  "postAttachCommand": "streamlit run streamlit_app.py --server.port 8501 --server.enableCORS false --server.enableXsrfProtection false",

  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openPreview"
    }
  },

  "forwardPorts": [8501]
}
